y\\\": \\\"ctrl+shift+r\\\",\\n    \\\"command\\\": \\\"-editor.action.refactor\\\",\\n    \\\"when\\\": \\\"editorHasCodeActionsProvider && textInputFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"shift+alt+up\\\",\\n    \\\"command\\\": \\\"-editor.action.insertCursorAbove\\\",\\n    \\\"when\\\": \\\"editorTextFocus\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"shift+alt+down\\\",\\n    \\\"command\\\": \\\"-editor.action.insertCursorBelow\\\",\\n    \\\"when\\\": \\\"editorTextFocus\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+shift+down\\\",\\n    \\\"command\\\": \\\"editor.action.copyLinesDownAction\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+shift+alt+down\\\",\\n    \\\"command\\\": \\\"-editor.action.copyLinesDownAction\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+shift+up\\\",\\n    \\\"command\\\": \\\"editor.action.copyLinesUpAction\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+shift+alt+up\\\",\\n    \\\"command\\\": \\\"-editor.action.copyLinesUpAction\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+alt+a\\\",\\n    \\\"command\\\": \\\"workbench.action.files.saveFiles\\\"\\n  }\\n]\\n\",\"platform\":2}","snippets":"{\"snippets\":{\"cpp.json\":\"{\\n  // Place your snippets for cpp here. Each snippet is defined under a snippet name and has a prefix, body and\\n  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the\\n  // same ids are connected.\\n  // Example:\\n  // \\\"Print to console\\\": {\\n  // \\t\\\"prefix\\\": \\\"log\\\",\\n  // \\t\\\"body\\\": [\\n  // \\t\\t\\\"console.log('$1');\\\",\\n  // \\t\\t\\\"$2\\\"\\n  // \\t],\\n  // \\t\\\"description\\\": \\\"Log output to console\\\"\\n  // }\\n  \\\"Include\\\": {\\n    \\\"prefix\\\": \\\"/include\\\",\\n    \\\"body\\\": [\\n      \\\"#include \\\\\\\"${0:header}\\\\\\\"\\\"\\n    ],\\n    \\\"description\\\": \\\"Include header file\\\"\\n  },\\n  \\\"Include Iostream\\\": {\\n    \\\"prefix\\\": \\\"/inciostream\\\",\\n    \\\"body\\\": [\\n      \\\"#include <iostream>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include iostream library\\\"\\n  },\\n  \\\"Include List\\\": {\\n    \\\"prefix\\\": \\\"/inclist\\\",\\n    \\\"body\\\": [\\n      \\\"#include <list>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include list library\\\"\\n  },\\n  \\\"Include vector\\\": {\\n    \\\"prefix\\\": \\\"/incvector\\\",\\n    \\\"body\\\": [\\n      \\\"#include <vector>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include vector library\\\"\\n  },\\n  \\\"Include pointer\\\": {\\n    \\\"prefix\\\": \\\"/incmemory\\\",\\n    \\\"body\\\": [\\n      \\\"#include <memory>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include memory library\\\"\\n  },\\n  \\\"Include format\\\": {\\n    \\\"prefix\\\": \\\"/incformat\\\",\\n    \\\"body\\\": [\\n      \\\"#include <format>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include format library\\\"\\n  },\\n  \\\"Include any\\\": {\\n    \\\"prefix\\\": \\\"/incany\\\",\\n    \\\"body\\\": [\\n      \\\"#include <any>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include any library\\\"\\n  },\\n  \\\"Include c int\\\": {\\n    \\\"prefix\\\": \\\"/inccint\\\",\\n    \\\"body\\\": [\\n      \\\"#include <cstdint>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include c standard int library\\\"\\n  },\\n  \\\"Include strin\\\": {\\n    \\\"prefix\\\": \\\"/incstring\\\",\\n    \\\"body\\\": [\\n      \\\"#include <string>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include string library\\\"\\n  },\\n  \\\"Include mutex\\\": {\\n    \\\"prefix\\\": \\\"/incmutex\\\",\\n    \\\"body\\\": [\\n      \\\"#include <mutex>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include mutex library\\\"\\n  },\\n  \\\"Include shared mutex\\\": {\\n    \\\"prefix\\\": \\\"/incmutexshr\\\",\\n    \\\"body\\\": [\\n      \\\"#include <shared_mutex>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include shared mutex library\\\"\\n  },\\n  \\\"Include thread\\\": {\\n    \\\"prefix\\\": \\\"/incthread\\\",\\n    \\\"body\\\": [\\n      \\\"#include <thread>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include thread library\\\"\\n  },\\n  \\\"Include atomic\\\": {\\n    \\\"prefix\\\": \\\"/incatomic\\\",\\n    \\\"body\\\": [\\n      \\\"#include <atomic>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include atomic library\\\"\\n  },\\n  \\\"Include chrono\\\": {\\n    \\\"prefix\\\": \\\"/incchrono\\\",\\n    \\\"body\\\": [\\n      \\\"#include <chrono>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include chrono library\\\"\\n  },\\n  \\\"Include algorithm\\\": {\\n    \\\"prefix\\\": \\\"/incalgo\\\",\\n    \\\"body\\\": [\\n      \\\"#include <algorithm>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include algorithm library\\\"\\n  },\\n  \\\"Include numeric\\\": {\\n    \\\"prefix\\\": \\\"/incnumeric\\\",\\n    \\\"body\\\": [\\n      \\\"#include <numeric>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include numeric library\\\"\\n  },\\n  \\\"Include limit\\\": {\\n    \\\"prefix\\\": \\\"/inclimit\\\",\\n    \\\"body\\\": [\\n      \\\"#include <limits>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include limit library\\\"\\n  },\\n  \\\"Include type info\\\": {\\n    \\\"prefix\\\": \\\"/inctypeinfo\\\",\\n    \\\"body\\\": [\\n      \\\"#include <typeinfo>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include type info library\\\"\\n  },\\n  \\\"Include map\\\": {\\n    \\\"prefix\\\": \\\"/incmap\\\",\\n    \\\"body\\\": [\\n      \\\"#include <map>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include map library\\\"\\n  },\\n  \\\"Include deque\\\": {\\n    \\\"prefix\\\": \\\"/incdeque\\\",\\n    \\\"body\\\": [\\n      \\\"#include <deque>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include deque library\\\"\\n  },\\n  \\\"Include unordered map\\\": {\\n    \\\"prefix\\\": \\\"/incunorderedmap\\\",\\n    \\\"body\\\": [\\n      \\\"#include <unordered_map>\\\"\\n    ],\\n    \\\"description\\\": \\\"Include unordered map library\\\"\\n  },\\n  \\\"Main\\\": {\\n    \\\"prefix\\\": \\\"/main\\\",\\n    \\\"body\\\": [\\n      \\\"int main()\\\",\\n      \\\"{\\\",\\n      \\\"  return 0;\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"Main function template\\\"\\n  },\\n  \\\"Enum\\\": {\\n    \\\"prefix\\\": \\\"/enum\\\",\\n    \\\"body\\\": [\\n      \\\"enum class ${1:EnumName}\\\",\\n      \\\"{\\\",\\n      \\\"};\\\"\\n    ],\\n    \\\"description\\\": \\\"Base enum template\\\"\\n  },\\n  \\\"Struct\\\": {\\n    \\\"prefix\\\": \\\"/struct\\\",\\n    \\\"body\\\": [\\n      \\\"struct ${1:StructName}\\\",\\n      \\\"{\\\",\\n      \\\"};\\\"\\n    ],\\n    \\\"description\\\": \\\"Base struct template\\\"\\n  },\\n  \\\"Class\\\": {\\n    \\\"prefix\\\": \\\"/class\\\",\\n    \\\"body\\\": [\\n      \\\"#pragma once\\\",\\n      \\\"\\\",\\n      \\\"class ${1:ClassName}\\\",\\n      \\\"{\\\",\\n      \\\"public:\\\",\\n      \\\"   ${1:ClassName}(){}\\\",\\n      \\\"protected:\\\",\\n      \\\"private:\\\",\\n      \\\"};\\\"\\n    ],\\n    \\\"description\\\": \\\"Base class template\\\"\\n  },\\n  \\\"Destructor\\\": {\\n    \\\"prefix\\\": \\\"/destructor\\\",\\n    \\\"body\\\": [\\n      \\\"~${1:ClassName}(){}\\\",\\n    ],\\n    \\\"description\\\": \\\"Destructor\\\"\\n  },\\n  \\\"Rule of 3\\\": {\\n    \\\"prefix\\\": \\\"/ro3\\\",\\n    \\\"body\\\": [\\n      \\\"~$CLIPBOARD() {}\\\",\\n      \\\"$CLIPBOARD(const $CLIPBOARD& other){}\\\",\\n      \\\"$CLIPBOARD& operator=(const $CLIPBOARD& other)\\\",\\n      \\\"{\\\",\\n      \\\"  if(&other == this)\\\",\\n      \\\"    return;\\\",\\n      \\\"  ${1:body}\\\",\\n      \\\"  return *this;\\\",\\n      \\\"}\\\",\\n    ],\\n    \\\"description\\\": \\\"Rule of 3 template\\\"\\n  },\\n  \\\"Rule of 5\\\": {\\n    \\\"prefix\\\": \\\"/ro5\\\",\\n    \\\"body\\\": [\\n      \\\"~$CLIPBOARD() {}\\\",\\n      \\\"$CLIPBOARD(const $CLIPBOARD& other){}\\\",\\n      \\\"$CLIPBOARD& operator=(const $CLIPBOARD& other)\\\",\\n      \\\"{\\\",\\n      \\\"  if(&other == this)\\\",\\n      \\\"    return *this;\\\",\\n      \\\"  ${1:/* body */}\\\",\\n      \\\"  return *this;\\\",\\n      \\\"}\\\",\\n      \\\"$CLIPBOARD($CLIPBOARD&& other) noexcept {}\\\",\\n      \\\"$CLIPBOARD& operator=($CLIPBOARD&& other) noexcept\\\",\\n      \\\"{\\\",\\n      \\\"  if(&other == this)\\\",\\n      \\\"    return *this;\\\",\\n      \\\"  ${2:/* body */}\\\",\\n      \\\"  return *this;\\\",\\n      \\\"}\\\",\\n    ],\\n    \\\"description\\\": \\\"Rule of 5 template\\\"\\n  },\\n  \\\"Getter\\\": {\\n    \\\"prefix\\\": \\\"/getter\\\",\\n    \\\"body\\\": [\\n      \\\"${1:returnType} ${2:FunctionName}() const { return ${3:memberVariable}; }\\\"\\n    ],\\n    \\\"description\\\": \\\"Const getter Function\\\"\\n  },\\n  \\\"Setter\\\": {\\n    \\\"prefix\\\": \\\"/setter\\\",\\n    \\\"body\\\": [\\n      \\\"void ${2:FunctionName}(const ${3:variableType}& ${4:variable}) { ${5:memberVariable} = ${4:variable}; }\\\"\\n    ],\\n    \\\"description\\\": \\\"Setter Function\\\"\\n  },\\n  \\\"Log\\\": {\\n    \\\"prefix\\\": \\\"/log\\\",\\n    \\\"body\\\": [\\n      \\\"std::cout << \\\\\\\"${1:message}\\\\\\\" << std::endl;\\\"\\n    ],\\n    \\\"description\\\": \\\"Logging\\\"\\n  },\\n  \\\"Function\\\": {\\n    \\\"prefix\\\": \\\"/function\\\",\\n    \\\"body\\\": [\\n      \\\"void ${1:FunctionName}()\\\",\\n      \\\"{\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"Logging\\\"\\n  },\\n  \\\"ForIterator\\\": {\\n    \\\"prefix\\\": \\\"/foriterator\\\",\\n    \\\"body\\\": [\\n      \\\"for(auto&& iterator = ${1:container}.begin(); iterator != ${1:container}.end(); iterator++)\\\",\\n      \\\"{\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"For Each Loop With Iterator\\\"\\n  },\\n  \\\"ForEach\\\": {\\n    \\\"prefix\\\": \\\"/foreach\\\",\\n    \\\"body\\\": [\\n      \\\"for(auto&& ${1:name} : ${2:container})\\\",\\n      \\\"{\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"For Each Loop\\\"\\n  },\\n  \\\"While\\\": {\\n    \\\"prefix\\\": \\\"/while\\\",\\n    \\\"body\\\": [\\n      \\\"while(${1:condition})\\\",\\n      \\\"{\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"While Loop\\\"\\n  },\\n  \\\"benchstart\\\": {\\n    \\\"prefix\\\": \\\"/benchStart\\\",\\n    \\\"body\\\": [\\n      \\\"auto startTime = std::chrono::high_resolution_clock::now();\\\",\\n    ],\\n    \\\"description\\\": \\\"Start point for benchmark\\\"\\n  },\\n  \\\"benchend\\\": {\\n    \\\"prefix\\\": \\\"/benchEnd\\\",\\n    \\\"body\\\": [\\n      \\\"auto endTime = std::chrono::high_resolution_clock::now();\\\",\\n      \\\"auto duration = endTime - startTime;\\\",\\n      \\\"std::cout << \\\\\\\"Duration: \\\\\\\" << duration.count() << std::endl;\\\",\\n    ],\\n    \\\"description\\\": \\\"End point and print the duration it takes\\\"\\n  },\\n  \\\"mutex\\\": {\\n    \\\"prefix\\\": \\\"/mutex\\\",\\n    \\\"body\\\": [\\n      \\\"mutable std::mutex ${0:mutex};\\\"\\n    ],\\n    \\\"description\\\": \\\"Mutex\\\"\\n  },\\n  \\\"mutexShare\\\": {\\n    \\\"prefix\\\": \\\"/mutexshare\\\",\\n    \\\"body\\\": [\\n      \\\"mutable std::shared_timed_mutex ${0:mutex};\\\"\\n    ],\\n    \\\"description\\\": \\\"Shared Time Mutex\\\"\\n  },\\n  \\\"lockGuard\\\": {\\n    \\\"prefix\\\": \\\"/lock\\\",\\n    \\\"body\\\": [\\n      \\\"std::lock_guard guard{${0:mutex}};\\\"\\n    ],\\n    \\\"description\\\": \\\"RAII guard lock\\\"\\n  },\\n  \\\"uniqueLock\\\": {\\n    \\\"prefix\\\": \\\"/lockuni\\\",\\n    \\\"body\\\": [\\n      \\\"std::unique_lock unique_lock{${0:mutex}};\\\"\\n    ],\\n    \\\"description\\\": \\\"RAII unique lock\\\"\\n  },\\n  \\\"scopeLock\\\": {\\n    \\\"prefix\\\": \\\"/lockscope\\\",\\n    \\\"body\\\": [\\n      \\\"std::scoped_lock scope_lock{${0:mutex}, ${1:mutex2}, ${2:mutex3}};\\\"\\n    ],\\n    \\\"description\\\": \\\"RAII unique lock\\\"\\n  },\\n  \\\"sharedLock\\\": {\\n    \\\"prefix\\\": \\\"/lockshared\\\",\\n    \\\"body\\\": [\\n      \\\"std::shared_lock share_lock{${0:mutex}};\\\"\\n    ],\\n    \\\"description\\\": \\\"RAII shared lock\\\"\\n  },\\n  \\\"Test\\\": {\\n    \\\"prefix\\\": \\\"/test\\\",\\n    \\\"body\\\": [\\n      \\\"std::cout << \\\\\\\"${1|message hello test|}\\\\\\\" << std::endl;\\\"\\n    ],\\n    \\\"description\\\": \\\"Test Snippet\\\"\\n  },\\n}\\n\",\"rust.json\":\"{\\n\\t// Place your snippets for rust here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"eserozvataf.one-dark-pro-monokai-darker\",\"uuid\":\"955e2d23-279c-44e2-81e1-ed2d3df7cec9\"},\"displayName\":\"One Dark Pro Monokai Darker Theme\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"evgeniypeshkov.syntax-highlighter\",\"uuid\":\"428c36f5-be8e-4df8-8992-233bf5aef31f\"},\"displayName\":\"Syntax Highlighter\",\"applicationScoped\":false},{\"identifier\":{\"id\":\